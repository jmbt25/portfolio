---
import Base from '../layouts/Base.astro';
import ProjectEntry from '../components/ProjectEntry.astro';
import { projects } from '../data/projects';

const handle = 'jmbt25';
---
<Base
  title={`projects — ${handle} (Data Scientist & AI Systems Engineer)`}
  description="Selected projects from jmbt25 — Claude-powered tools, MCP servers, async Python data pipelines, and a browser 3D life simulation."
  current="projects"
>
  <h1>projects</h1>
  <p class="subtitle">things i've built, recent first</p>

  <section>
    <h2>log</h2>
    {projects.map((p) => <ProjectEntry project={p} expanded />)}
  </section>
</Base>

---
import Base from '../layouts/Base.astro';
import ProjectEntry from '../components/ProjectEntry.astro';
import { projects } from '../data/projects';

const handle = 'jmbt25';
const displayName = 'joshua';

const title = `${handle} — Data Scientist & AI Systems Engineer`;
const description = 'Six years building data and ML systems in Manila. Currently at MBM IT Consulting, shipping MCP servers, NLP pipelines and Claude-powered tools.';

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Joshua',
  alternateName: 'jmbt25',
  url: 'https://jmbt.dev',
  image: 'https://jmbt.dev/og.png',
  jobTitle: 'Data Scientist & AI Systems Engineer',
  worksFor: { '@type': 'Organization', name: 'MBM IT Consulting' },
  alumniOf: { '@type': 'EducationalOrganization', name: 'Asian Institute of Management' },
  address: { '@type': 'PostalAddress', addressLocality: 'Manila', addressCountry: 'PH' },
  sameAs: ['https://github.com/jmbt25', 'https://x.com/jmbt_dev'],
  knowsAbout: ['Python', 'Claude API', 'Model Context Protocol', 'Data Pipelines', 'Large Language Models'],
};
---
<Base title={title} description={description} current="home">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <section>
    <h1 class="hero-name">{displayName}<span class="cursor" aria-hidden="true"></span></h1>
    <p class="role">data scientist · ai systems engineer</p>
    <p>Six years building data and ML systems. Currently at MBM IT Consulting. MS in Data Science from the Asian Institute of Management.</p>
    <p>I spend most of my day in Claude Code, shipping AI-powered tools — MCP servers, NLP pipelines, LLM integrations — and the kind of small, opinionated software I want to exist.</p>
  </section>

  <section>
    <h2>selected work</h2>
    {projects.map((p) => <ProjectEntry project={p} />)}
  </section>

  <section>
    <h2>elsewhere</h2>
    <p>
      <a href={`https://github.com/${handle}`} target="_blank" rel="noopener">github.com/{handle}</a>
      <span class="dim"> · code, in progress and otherwise</span>
    </p>
    <p>
      <a href="https://x.com/jmbt_dev" target="_blank" rel="noopener">x.com/jmbt_dev</a>
      <span class="dim"> · open for contact</span>
    </p>
  </section>
</Base>
